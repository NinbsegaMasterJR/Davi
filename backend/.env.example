# Configurações do Pregador IA Backend

# Servidor
PORT=3001
NODE_ENV=development

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Bible API (BibleAPI.com ou equivalente)
BIBLE_API_KEY=your_bible_api_key_here
BIBLE_API_URL=https://api.bible.com/v1

# CORS
CORS_ORIGIN=http://localhost:3000

# Database (opcional, se quiser adicionar persistência)
DATABASE_URL=
