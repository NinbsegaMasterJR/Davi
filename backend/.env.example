# Configurações do Pregador IA Backend

# Servidor
PORT=3001
NODE_ENV=development

# Groq (IA rápida e gratuita)
GROQ_API_KEY=gsk_your_groq_api_key_here

# CORS
# Em produção, informe a URL do frontend. Para múltiplas URLs, separe por vírgula.
CORS_ORIGIN=http://localhost:3000

# Database (opcional, se quiser adicionar persistência)
DATABASE_URL=
